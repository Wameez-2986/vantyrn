enum ReviewDecision {
  approved
  rejected

  @@schema("admin")
}

enum RefundStatus {
  initiated
  success
  failed

  @@schema("admin")
}

enum CommissionModel {
  ADD_ON
  DEDUCTED

  @@schema("vendor_delivery")
}

enum PricingScope {
  global
  product

  @@schema("admin")
}

enum AccountStatus {
  KYC_SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
  DISABLED
  ACTIVE
  PENDING

  @@schema("vendor_delivery")
}

enum VendorRejectReason {
  STORE_CLOSED
  KITCHEN_CLOSED
  ITEMS_UNAVAILABLE
  UNABLE_TO_FULFILL
  STAFF_UNAVAILABLE
  TECHNICAL_ISSUE
  OTHER

  @@schema("vendor_delivery")
}

enum NotificationType {
  ORDER
  KYC
  SYSTEM
  CUSTOMER

  @@schema("admin")
}

enum CustomizationType {
  NORMAL
  BUILD_YOUR_OWN

  @@schema("vendor_delivery")
}
